<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Média do Aluno</title>

    <style>
        body{
            font-family: Arial, sans-serif;
            margin: 40px;
        }

        input, button{
            padding: 10px;
            margin-top: 10px;
        }

        .resultado{
            margin-top: 20px;
            border: 1px solid #ccc;
            padding: 15px;
            width: 350px;
        }

        /* Estilo para a lista de erros */
        .erros {
            background-color: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
            padding: 10px;
            width: 350px;
            margin-bottom: 20px;
            border-radius: 4px;
        }
        .erros ul {
            margin: 0;
            padding-left: 20px;
        }
    </style>
</head>
<body>

    <h1>Cálculo da Média</h1>

    <% if(typeof errors !== 'undefined' && errors.length > 0) { %>
        <div class="erros">
            <strong>Por favor, corrija os seguintes erros:</strong>
            <ul>
                <% errors.forEach(function(error) { %>
                    <li><%= error.msg %></li>
                <% }); %>
            </ul>
        </div>
    <% } %>

    <form method="POST">

        <label>Primeira nota:</label><br>
        <input type="number" step="0.1" name="nota1" min="0" max="10" value="<%= typeof nota1 !== 'undefined' ? nota1 : '' %>" required>

        <br><br>

        <label>Segunda nota:</label><br>
        <input type="number" step="0.1" name="nota2" min="0" max="10" value="<%= typeof nota2 !== 'undefined' ? nota2 : '' %>" required>

        <br><br>

        <button type="submit">
            Calcular
        </button>

    </form>

    <% if(typeof media !== "undefined" && media !== null && errors.length === 0){ %>

        <div class="resultado">

            <h2>Resultado</h2>

            <p>
                <strong>Nota 1:</strong>
                <%= nota1 %>
            </p>

            <p>
                <strong>Nota 2:</strong>
                <%= nota2 %>
            </p>

            <p>
                <strong>Média:</strong>
                <%= media.toFixed(2) %>
            </p>

            <p>
                <strong>Conceito:</strong>
                <%= conceito %>
            </p>

        </div>

    <% } %>

</body>
</html>
