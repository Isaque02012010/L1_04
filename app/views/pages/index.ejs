<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Média do Aluno</title>

    <style>
        body{
            font-family: Arial;
            margin: 40px;
        }

        input, button{
            padding: 10px;
            margin-top: 10px;
        }

        .resultado{
            margin-top: 20px;
            border: 1px solid #ccc;
            padding: 15px;
            width: 350px;
        }
    </style>
</head>
<body>

    <h1>Cálculo da Média</h1>

    <form method="POST">

        <label>Primeira nota:</label><br>
        <input type="number" step="0.1" name="nota1" required>

        <br><br>

        <label>Segunda nota:</label><br>
        <input type="number" step="0.1" name="nota2" required>

        <br><br>

        <button type="submit">
            Calcular
        </button>

    </form>

    <% if(typeof media !== "undefined"){ %>

        <div class="resultado">

            <h2>Resultado</h2>

            <p>
                <strong>Nota 1:</strong>
                <%= nota1 %>
            </p>

            <p>
                <strong>Nota 2:</strong>
                <%= nota2 %>
            </p>

            <p>
                <strong>Média:</strong>
                <%= media.toFixed(2) %>
            </p>

            <p>
                <strong>Conceito:</strong>
                <%= conceito %>
            </p>

        </div>

    <% } %>

</body>
</html>